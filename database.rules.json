{
  "rules": {
    "channels": {
      "$channelName": {
        ".read": "auth != null",
        ".write": "auth != null",
        "meta": {
          ".validate": "newData.hasChildren(['passwordHash', 'createdAt'])"
        },
        "slots": {
          "slot1": {
            ".validate": "newData.hasChildren(['nick', 'sessionId', 'online', 'lastSeen']) && (!newData.child('clientInfo').exists() || newData.child('clientInfo').hasChildren(['appVersion', 'platform']))"
          },
          "slot2": {
            ".validate": "newData.hasChildren(['nick', 'sessionId', 'online', 'lastSeen']) && (!newData.child('clientInfo').exists() || newData.child('clientInfo').hasChildren(['appVersion', 'platform']))"
          }
        },
        "liveTyping": {
          "$slotId": {
            ".validate": "newData.isString()"
          }
        },
        "liveCursor": {
          "$slotId": {
            ".validate": "newData.hasChildren(['nick', 'offset', 'updatedAt'])"
          }
        },
        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['senderNick', 'senderSlotId', 'text', 'timestamp', 'deliveredSlots', 'readSlots'])"
          }
        },
        "messageCleanupRequest": {
          ".validate": "newData.hasChildren(['requestId', 'requesterSessionId', 'requesterSlotId', 'requesterNick', 'requestedAt', 'keepDurationMs', 'cleanupMode'])"
        },
        "messageCleanupResult": {
          ".validate": "newData.hasChildren(['requestId', 'requesterSessionId', 'requesterNick', 'responderNick', 'status', 'completedAt', 'deletedCount'])"
        }
      }
    }
  }
}